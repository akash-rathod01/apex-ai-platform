.env*.local

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

# ============================================
# APEX AI PLATFORM SPECIFIC
# ============================================

# Per-app memory databases (DO NOT COMMIT)
core/memory/*.db
core/memory/*.db-journal
core/memory/*.db-wal
core/memory/*.db-shm

# Per-app snapshots and baselines (LARGE FILES)
apps/*/snapshots/**/*.png
apps/*/snapshots/**/*.jpg
apps/*/snapshots/**/*.jpeg
apps/*/snapshots/**/*.mp4
apps/*/snapshots/**/*.webm

# BUT keep snapshot directories structure
!apps/*/snapshots/.gitkeep
!apps/*/snapshots/ui/.gitkeep
!apps/*/snapshots/api/.gitkeep
!apps/*/snapshots/performance/.gitkeep

# Per-app execution logs (DO NOT COMMIT)
apps/*/logs/**/*.log
apps/*/logs/**/*.txt

# BUT keep log directories
!apps/*/logs/.gitkeep

# Observability data (metrics/traces are too large)
observability/logs/**/*.log
observability/metrics/**/*.json
observability/traces/**/*.json

# Runtime test execution artifacts
runtime/sandbox/**/screenshots/
runtime/sandbox/**/videos/
runtime/sandbox/**/downloads/
runtime/sandbox/**/traces/

# Plugin cache
plugins/.cache/
plugins/**/__pycache__/

# LLM model cache (DO NOT COMMIT)
.model_cache/
models/*.bin
models/*.gguf
models/*.safetensors

# Ollama models (managed by Ollama)
.ollama/

# Environment variables
.env
.env.local
.env.production
.env.development

# API keys and secrets
secrets/
*.key
*.pem
*.crt

# Temporary files
*.tmp
*.temp
.temp/
tmp/

# IDE and Editor files
.vscode/settings.json
.vscode/launch.json
.idea/
*.swp
*.swo
*~

# BUT keep .vscode with recommended extensions
!.vscode/extensions.json
!.vscode/settings.template.json

# OS files
Thumbs.db
.DS_Store
desktop.ini

# Docker
*.env.docker
docker-compose.override.yml

# CI/CD artifacts
.github/workflows/secrets.yml
cicd/**/*.env

# Performance test results
performance_results/
load_test_results/

# Security scan results
security_reports/
vulnerability_scans/

# Backup files
*.bak
*.backup
*~

# ============================================
# EXCEPTIONS (FILES TO ALWAYS COMMIT)
# ============================================

# Keep example files
!.env.example
!apps/app1/.env.example
!environments/dev/.env.example

# Keep placeholder files
!**/.gitkeep

# Keep documentation
!**/*.md

# Keep configuration templates
!apps/**/config.example.yaml
!apps/**/rules.example.yaml

# Keep blueprint examples
!apps/*/blueprints/examples/

# Keep small test fixtures (< 1MB)
!tests/fixtures/**
