# Apex AI Platform - Environment Configuration Template
# Copy this file to .env and update with your values

# ============================================
# LLM CONFIGURATION
# ============================================

# LLM Provider: ollama, openai, anthropic, azure
LLM_PROVIDER=ollama

# Ollama Configuration (Local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
# Alternative models: llama3.1:7b, nemotron-mini, deepseek-coder

# OpenAI Configuration (Remote LLM)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4
OPENAI_ORG_ID=your_org_id_here

# Anthropic Configuration (Remote LLM)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Azure OpenAI Configuration
AZURE_OPENAI_ENDPOINT=your_azure_endpoint_here
AZURE_OPENAI_API_KEY=your_azure_key_here
AZURE_OPENAI_DEPLOYMENT=your_deployment_name

# ============================================
# PLATFORM CONFIGURATION
# ============================================

# Environment: development, staging, production
ENVIRONMENT=development

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
ENABLE_DEBUG_LOGS=false

# Execution
MAX_PARALLEL_AGENTS=5
DEFAULT_TIMEOUT_MS=30000
ENABLE_RETRIES=true
MAX_RETRIES=3

# Auto-Healing
ENABLE_AUTO_HEALING=true
AUTO_HEALING_CONFIDENCE_THRESHOLD=0.8

# ============================================
# DATABASE CONFIGURATION
# ============================================

# SQLite (default - per-app databases)
MEMORY_DB_PATH=core/memory/

# PostgreSQL (optional - for team scaling)
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=apex_ai
# POSTGRES_USER=apex_user
# POSTGRES_PASSWORD=your_password_here

# ============================================
# WEB UI CONFIGURATION
# ============================================

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# ============================================
# RUNTIME CONFIGURATION
# ============================================

# Playwright
PLAYWRIGHT_BROWSERS_PATH=0
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_SLOW_MO=0

# Selenium
SELENIUM_GRID_URL=http://localhost:4444
SELENIUM_HEADLESS=true

# ============================================
# PLUGIN CONFIGURATION
# ============================================

# Performance Testing
K6_CLOUD_TOKEN=your_k6_cloud_token_here
LOCUST_WEB_PORT=8089

# Security Testing
ZAP_API_KEY=your_zap_api_key_here
ZAP_ADDRESS=http://localhost:8080

# ============================================
# CI/CD INTEGRATION
# ============================================

# GitHub Actions
GITHUB_TOKEN=your_github_token_here
GITHUB_REPO=your_username/apex-ai-platform

# Jenkins
JENKINS_URL=http://localhost:8080
JENKINS_USER=your_jenkins_user
JENKINS_TOKEN=your_jenkins_token

# GitLab CI
GITLAB_TOKEN=your_gitlab_token_here
GITLAB_PROJECT_ID=your_project_id

# ============================================
# OBSERVABILITY
# ============================================

# Metrics
ENABLE_METRICS=true
METRICS_PORT=9090

# Traces
ENABLE_TRACING=false
JAEGER_ENDPOINT=http://localhost:14268/api/traces

# Logs
ENABLE_LOG_AGGREGATION=false
ELASTICSEARCH_URL=http://localhost:9200

# ============================================
# SECURITY
# ============================================

# API Security
API_SECRET_KEY=your_secret_key_here_minimum_32_characters
API_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Test Data Encryption
ENABLE_ENCRYPTION=false
ENCRYPTION_KEY=your_encryption_key_here

# ============================================
# NOTIFICATIONS
# ============================================

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
ALERT_EMAIL_TO=alerts@your-company.com

# Slack
SLACK_WEBHOOK_URL=your_slack_webhook_url_here
SLACK_CHANNEL=#test-alerts

# ============================================
# FEATURE FLAGS
# ============================================

ENABLE_TEST_INTELLIGENCE=true
ENABLE_FLAKINESS_DETECTION=true
ENABLE_RISK_SCORING=true
ENABLE_VISUAL_REGRESSION=true
ENABLE_PERFORMANCE_BASELINES=true
